# Copy to .env and fill in keys (or leave MOCK_MODE=true to run without providers).

# When true, skips the scraper and every provider render call, using fixtures.
MOCK_MODE=true

# Required in live mode (MOCK_MODE=false):
ANTHROPIC_API_KEY=          # Director (claude-sonnet-5)
HIGGSFIELD_API_KEY=         # Render (dop-turbo)
HIGGSFIELD_API_SECRET=
APIFY_TOKEN=                # Airbnb scraper
CREATOMATE_API_KEY=         # Stitch (raw token, no "Bearer")
FAL_KEY=                    # Fal render

# Optional overrides:
# HIGGSFIELD_ACCOUNTS=key1:secret1,key2:secret2   # shard render jobs across accounts
# RENDER_CONCURRENCY=1
# RENDER_HERO_WITH_VEO=false
# SKIP_STITCH=false
# FINAL_PLAYBACK_SPEED=0.7    # slow the final film with ffmpeg (1 = off; needs ffmpeg)
# APIFY_AIRBNB_ACTOR=tri_angle~airbnb-rooms-urls-scraper
# CREATOMATE_MUSIC_URL=https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3
